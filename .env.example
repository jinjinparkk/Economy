# LLM 공급자: "gemini" | "claude"
LLM_PROVIDER=gemini

# Gemini API (https://aistudio.google.com/apikey 에서 무료 발급)
GEMINI_API_KEY=AIzaSy_xxxxx

# Claude API (선택, LLM_PROVIDER=claude 일 때)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# 네이버 뉴스 API (선택, 없으면 Google News RSS 사용)
NAVER_CLIENT_ID=xxxxx
NAVER_CLIENT_SECRET=xxxxx

# DART API (https://opendart.fss.or.kr 에서 무료 발급)
DART_API_KEY=xxxxx

# 출력 설정
OUTPUT_DIR=./output
TIMEZONE=Asia/Seoul

# 급등/급락 탐지 기준
MOVER_THRESHOLD_PCT=5.0
VOLUME_SURGE_MULTIPLIER=3.0
TOP_N_MOVERS=5

# WordPress.com 자동 포스팅 (선택, 없으면 비활성화)
WP_ACCESS_TOKEN=
WP_SITE_ID=
WP_AUTO_PUBLISH=true

# 텔레그램 채널 자동 발송 (선택, 없으면 비활성화)
TELEGRAM_BOT_TOKEN=            # @BotFather에서 발급
TELEGRAM_CHANNEL_ID=           # @channel_name 또는 숫자ID
TELEGRAM_AUTO_POST=false       # true로 바꾸면 활성화

# 네이버 블로그 자동 포스팅 (선택, 없으면 비활성화)
NAVER_ACCESS_TOKEN=            # scripts/get_naver_token.py로 발급
NAVER_AUTO_PUBLISH=false       # true로 바꾸면 활성화
